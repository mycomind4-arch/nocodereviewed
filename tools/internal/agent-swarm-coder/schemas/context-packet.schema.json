{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "context-packet.schema.json",
  "title": "AgentContextPacket",
  "description": "Context packet generated by agent-swarm-coder from prior local Vault ingestion normalized records. Provides memory of previous runs for improved planning without auto-applying or weakening safety. Records are selected via deterministic ranking, with uncertainty notes. Source of truth remains the raw agent run artifacts + Vault normalized records.",
  "type": "object",
  "required": ["goal", "generated_at", "selected_records_count", "relevant_prior_runs", "relevant_decisions", "relevant_evidence", "relevant_commands", "relevant_rollbacks", "relevant_next_actions", "reusable_patterns", "risks_from_memory", "what_not_to_repeat", "recommended_strategy", "confidence_notes"],
  "properties": {
    "goal": { "type": "string" },
    "generated_at": { "type": "string" },
    "project": { "type": "string" },
    "selected_records_count": { "type": "integer" },
    "loaded_records_count": { "type": "integer" },
    "relevant_prior_runs": {
      "type": "array",
      "items": { "type": "object" }
    },
    "relevant_decisions": { "type": "array", "items": { "type": "object" } },
    "relevant_evidence": { "type": "array", "items": { "type": "object" } },
    "relevant_commands": { "type": "array", "items": { "type": "object" } },
    "relevant_rollbacks": { "type": "array", "items": { "type": "object" } },
    "relevant_next_actions": { "type": "array", "items": { "type": "object" } },
    "reusable_patterns": { "type": "array", "items": { "type": "string" } },
    "risks_from_memory": { "type": "array", "items": { "type": "string" } },
    "what_not_to_repeat": { "type": "array", "items": { "type": "string" } },
    "recommended_strategy": { "type": "array", "items": { "type": "string" } },
    "confidence_notes": { "type": "string" },
    "stale_or_low_confidence_records": { "type": "array", "items": { "type": "object" } },
    "source_ingestion_dirs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
